MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8787
MCP_HTTP_API_KEY=
DATA_DIR=./data
LOG_LEVEL=INFO

# Browser session mode. Use a visible local browser and reuse this profile.
DOUYIN_BROWSER_PROFILE_DIR=./data/browser-profile
DOUYIN_BROWSER_HEADLESS=false
DOUYIN_BROWSER_AUTO_CLOSE=true
DOUYIN_BROWSER_CHANNEL=chrome
DOUYIN_BROWSER_PAGE_SETTLE_MS=5000
DOUYIN_LIST_CACHE_TTL_HOURS=24
DOUYIN_DETAIL_CACHE_TTL_HOURS=24
DOUYIN_DETAIL_BATCH_SIZE=10
DOUYIN_PROFILE_LOCK_FILENAME=.douyin-mcp.lock
DOUYIN_LIST_PARSER_VERSION=creator-manage-v2
DOUYIN_DETAIL_PARSER_VERSION=creator-detail-v2
DOUYIN_CREATOR_HOME_URL=https://creator.douyin.com/
DOUYIN_CREATOR_VIDEO_URL=https://creator.douyin.com/creator-micro/content/manage

# Video transcript pipeline. Models must already exist locally; runtime downloads are disabled.
TRANSCRIPT_INGESTION_ENABLED=false
TRANSCRIPT_PIPELINE_VERSION=transcript-v1
TRANSCRIPT_WORKER_COUNT=1
TRANSCRIPT_LEASE_SECONDS=30
TRANSCRIPT_HEARTBEAT_SECONDS=5
TRANSCRIPT_MAX_ATTEMPTS=2
TRANSCRIPT_RESPONSE_MAX_BYTES=262144
TRANSCRIPT_DEFAULT_MAX_CHARS=12000
TRANSCRIPT_MEDIA_MAX_BYTES=536870912
TRANSCRIPT_MEDIA_MIN_FREE_BYTES=1073741824
TRANSCRIPT_BUNDLE_MIN_OBSERVE_MS=1500
TRANSCRIPT_BUNDLE_MULTI_STABLE_MS=350
TRANSCRIPT_BUNDLE_SINGLE_STABLE_MS=750
TRANSCRIPT_BUNDLE_MAX_OBSERVE_MS=6000
TRANSCRIPT_FFMPEG_PATH=ffmpeg
TRANSCRIPT_FFPROBE_PATH=ffprobe
TRANSCRIPT_PROCESS_TIMEOUT_SECONDS=600
TRANSCRIPT_ASR_MODEL_DIR=
TRANSCRIPT_ASR_MODEL_SIZE=small
TRANSCRIPT_ASR_DEVICE=cpu
TRANSCRIPT_ASR_COMPUTE_TYPE=int8
TRANSCRIPT_KEEP_REFERENCE_VIDEO=false

# Hybrid ingestion policy. These only apply when TRANSCRIPT_INGESTION_ENABLED=true.
# First successful inventory sync queues only the latest N missing public videos.
TRANSCRIPT_AUTO_WARMUP_ENABLED=true
TRANSCRIPT_WARMUP_RECENT_LIMIT=5
# Later inventory syncs queue newly discovered public videos, bounded per sync.
TRANSCRIPT_AUTO_INGEST_NEW_VIDEOS=true
TRANSCRIPT_AUTO_NEW_VIDEO_LIMIT=20
# A missing AI context request queues its transcript and returns a run_id to poll.
TRANSCRIPT_AUTO_PREPARE_ANALYSIS=true
